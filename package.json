{
  "name": "@truenas/api-client",
  "version": "0.0.0",
  "description": "Framework-agnostic TypeScript client for the TrueNAS JSON-RPC 2.0 WebSocket API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "yarn build",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spec.json && tsc -p tsconfig.scripts.json",
    "generate:api": "tsx scripts/generate-api-interface/generate.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "check:dist": "node scripts/check-dist.mjs",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "check:package": "publint && yarn pack -o package.tgz && attw package.tgz && rm -f package.tgz",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/js": "^9.18.0",
    "@semantic-release/github": "^11.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.18.0",
    "json-schema-to-typescript": "^15.0.4",
    "publint": "^0.3.21",
    "rxjs": "~7.8.0",
    "semantic-release": "^24.2.1",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.10.3",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truenas/api-client-ts.git"
  },
  "keywords": [
    "truenas",
    "api",
    "client",
    "websocket",
    "json-rpc"
  ]
}
