import type {
  QueryFilters,
  QueryOptions,
} from '../shared/query-types';

import type {
  ISCSIThing,
  TestCreate,
  TestEntry,
  Widget,
  WidgetInput,
} from './api-types';

export interface ApiCallDirectory {
  /**
   * Create a test item.
   * @roles TEST_WRITE
   */
  'test.create': {
    params: [data: TestCreate];
    response: TestEntry;
  };

  /**
   * Update a widget.
   * @roles TEST_WRITE
   * @deprecated Removed in API version v3.0.0.
   */
  'test.update': {
    params: [widget: WidgetInput];
    response: null;
  };

  /**
   * Get the widget.
   * @roles TEST_READ
   */
  'test.get': {
    params: [];
    response: Widget;
  };

  /**
   * Query test items.
   * @roles TEST_READ
   */
  'test.query': {
    params: [filters?: QueryFilters<TestEntry>, options?: QueryOptions<TestEntry>];
    response: TestEntry[] | TestEntry | number;
  };

  /**
   * Fetch the iSCSI thing.
   * @roles TEST_READ
   */
  'iscsi.fetch': {
    params: [];
    response: ISCSIThing;
  };
}
